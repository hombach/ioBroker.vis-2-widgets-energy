{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "jsx": "react-jsx",
        "allowJs": true,
        "checkJs": false,
        "noEmit": true,
        "skipLibCheck": true,
        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true,
        "resolveJsonModule": true,
        "strict": false
    },
    "include": ["src-widgets/src/**/*", "*.mjs"],
    "exclude": ["node_modules", "src-widgets/node_modules", "src-widgets/build", "widgets", "build", "tmp"]
}
